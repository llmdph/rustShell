import { Theme } from "../theme.slint";

export component IconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label: "";
    in property <bool> primary: false;
    in property <bool> danger: false;
    callback clicked();

    width: label == "" ? 30px : 70px;
    height: 28px;
    border-width: 1px;
    border-radius: 4px;
    border-color: primary ? Theme.primary : danger ? Theme.danger : Theme.line;
    background: touch.pressed ? Theme.selected : touch.has-hover ? Theme.hover : primary ? Theme.primary : Theme.panel2;

    HorizontalLayout {
        padding-left: label == "" ? 7px : 8px;
        padding-right: label == "" ? 7px : 8px;
        spacing: 6px;
        alignment: center;
        Image {
            width: 14px;
            height: 14px;
            source: root.icon;
        }
        Text {
            visible: root.label != "";
            text: root.label;
            color: Theme.text;
            font-size: 12px;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component TextButton inherits Rectangle {
    in property <string> text: "";
    in property <bool> primary: false;
    callback clicked();

    height: 28px;
    min-width: 52px;
    border-width: 1px;
    border-radius: 4px;
    border-color: primary ? Theme.primary : Theme.line;
    background: touch.pressed ? Theme.selected : touch.has-hover ? Theme.hover : primary ? Theme.primary : Theme.panel2;

    Text {
        text: root.text;
        color: Theme.text;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component TextField inherits Rectangle {
    in-out property <string> text: "";
    in property <string> placeholder: "";

    height: 28px;
    border-width: 1px;
    border-radius: 4px;
    border-color: Theme.line;
    background: Theme.input;
    forward-focus: input;

    input := TextInput {
        x: 8px;
        y: 0px;
        width: parent.width - 16px;
        height: parent.height;
        text <=> root.text;
        color: Theme.text;
        selection-background-color: Theme.primary;
        selection-foreground-color: #ffffff;
        font-size: 12px;
        vertical-alignment: center;
        single-line: true;
        text-cursor-width: 1px;
    }

    Text {
        visible: root.text == "" && !input.has-focus;
        x: 8px;
        y: 0px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.placeholder;
        color: Theme.muted;
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component SectionHeader inherits Rectangle {
    in property <string> title: "";
    in property <string> value: "";
    height: 25px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        text: root.title;
        color: Theme.text;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

export component StatusDot inherits Rectangle {
    in property <string> status: "disconnected";
    width: 7px;
    height: 7px;
    border-radius: 4px;
    background: status == "connected" ? #38d37a : status == "connecting" ? Theme.warn : status == "failed" ? Theme.danger : #91a0af;
}

export component MonoText inherits Text {
    color: Theme.text;
    font-family: "Cascadia Mono, Consolas, Microsoft YaHei UI, monospace";
    font-size: 13px;
    wrap: no-wrap;
}
