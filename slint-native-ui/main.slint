import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { IconButton, TextButton, TextField, SectionHeader, StatusDot, MonoText } from "components/widgets.slint";

export struct SessionNodeVm {
    id: string,
    name: string,
    protocol: string,
    status: string,
    depth: int,
    is-folder: bool,
    selected: bool,
}

export struct TerminalTabVm {
    id: string,
    title: string,
    status: string,
    active: bool,
}

export struct TerminalLineVm {
    text: string,
}

export struct FileEntryVm {
    name: string,
    path: string,
    kind: string,
    permissions: string,
    owner: string,
    size: string,
    modified: string,
    is-dir: bool,
    selected: bool,
}

component WindowButton inherits Rectangle {
    in property <string> symbol: "";
    callback clicked();
    width: 34px;
    height: 34px;
    background: touch.has-hover ? Theme.hover : transparent;
    Text {
        text: root.symbol;
        color: Theme.muted;
        font-size: 16px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component TopMenu inherits Rectangle {
    callback open-file-manager();
    callback open-settings();
    callback open-local();
    height: 50px;
    background: Theme.chrome;
    border-width: 1px;
    border-color: Theme.line;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 14px;
        padding-right: 10px;
        spacing: 18px;

        Image {
            width: 28px;
            height: 28px;
            source: @image-url("../icons/rustshell-logo.svg");
        }
        Text {
            width: 112px;
            text: "RustShell";
            color: Theme.text;
            font-size: 17px;
            font-weight: 800;
        }
        TextButton { text: "文件(F)"; clicked => { root.open-file-manager(); } }
        TextButton { text: "连接(C)"; }
        TextButton { text: "工具(T)"; clicked => { root.open-file-manager(); } }
        TextButton { text: "选项(O)"; clicked => { root.open-settings(); } }
        TextButton { text: "窗口(W)"; }
        TextButton { text: "帮助(H)"; }
        Rectangle { horizontal-stretch: 1; background: transparent; }
    }
}

component SessionPanel inherits Rectangle {
    in property <[SessionNodeVm]> rows;
    in property <string> search: "";
    in property <string> preview-name: "";
    in property <string> preview-host: "";
    in property <string> preview-user: "";
    in property <string> preview-protocol: "";
    in property <string> preview-port: "";
    callback refresh();
    callback select(string);
    callback connect(string);

    width: 272px;
    background: Theme.panel;
    border-width: 1px;
    border-color: Theme.line;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 8px;
        spacing: 6px;

        HorizontalLayout {
            height: 28px;
            SectionHeader { title: "会话管理器"; horizontal-stretch: 1; }
            IconButton { icon: @image-url("assets/icons/plus.svg"); clicked => { root.refresh(); } }
            IconButton { icon: @image-url("assets/icons/chevron-left.svg"); }
        }
        TextField {
            text: root.search;
            placeholder: "搜索会话";
        }
        ScrollView {
            vertical-stretch: 1;
            Rectangle {
                height: 900px;
                background: transparent;
                VerticalLayout {
                    spacing: 1px;
                    for row in root.rows : Rectangle {
                        height: row.is-folder ? 22px : 20px;
                        background: row.selected ? Theme.selected : touch.has-hover ? Theme.hover : transparent;
                        StatusDot {
                            visible: !row.is-folder;
                            x: 34px + row.depth * 13px;
                            y: 7px;
                            status: row.status;
                        }
                        Text {
                            x: row.is-folder ? 6px + row.depth * 13px : 48px + row.depth * 13px;
                            width: parent.width - self.x - 42px;
                            text: row.is-folder ? "⌄  " + row.name : row.name;
                            color: row.is-folder ? Theme.muted : Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        Text {
                            visible: !row.is-folder;
                            x: parent.width - 38px;
                            width: 36px;
                            text: row.protocol;
                            color: Theme.muted;
                            font-size: 10px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        touch := TouchArea {
                            clicked => {
                                root.select(row.id);
                            }
                            double-clicked => {
                                root.connect(row.id);
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 110px;
            background: Theme.panel2;
            border-width: 1px;
            border-color: Theme.line;
            border-radius: 4px;
            VerticalLayout {
                padding: 7px;
                spacing: 4px;
                Text { text: "连接概览"; color: Theme.text; font-size: 12px; font-weight: 700; }
                Text { text: "名称    " + root.preview-name + "    主机    " + root.preview-host; color: Theme.text; font-size: 12px; }
                Text { text: "协议    " + root.preview-protocol + "    用户    " + root.preview-user; color: Theme.muted; font-size: 12px; }
                Text { text: "端口    " + root.preview-port; color: Theme.muted; font-size: 12px; }
                Text { text: "暂无状态数据"; color: Theme.muted; font-size: 12px; }
            }
        }
    }
}

component TerminalArea inherits Rectangle {
    in property <[TerminalTabVm]> tabs;
    in property <[TerminalLineVm]> lines;
    in-out property <string> command: "";
    callback send-command(string);
    callback control(string);

    background: Theme.terminal;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 0px;
        Rectangle {
            height: 30px;
            background: Theme.chrome;
            border-width: 1px;
            border-color: Theme.line;
            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: 7px;
                spacing: 0px;
                for tab in root.tabs : Rectangle {
                    width: 138px;
                    height: 29px;
                    background: tab.active ? Theme.hover : transparent;
                    border-width: 1px;
                    border-color: tab.active ? Theme.primary : Theme.line;
                    StatusDot { x: 8px; y: 11px; status: tab.status; }
                    Text {
                        x: 22px;
                        width: parent.width - 44px;
                        text: tab.title;
                        color: Theme.text;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    Text {
                        x: parent.width - 18px;
                        width: 16px;
                        text: "×";
                        color: Theme.muted;
                        font-size: 14px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.terminal;
            border-width: 1px;
            border-color: #111820;
            ScrollView {
                width: parent.width;
                height: parent.height;
                Rectangle {
                    height: root.lines.length * 18px + 24px;
                    background: transparent;
                    VerticalLayout {
                        padding-top: 10px;
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 0px;
                        for line in root.lines : MonoText {
                            height: 18px;
                            text: line.text;
                            color: Theme.mode == 2 ? #152033 : #f3f7ff;
                            font-size: 13px;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 44px;
            background: Theme.chrome;
            border-width: 1px;
            border-color: Theme.line;
            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                padding: 7px;
                spacing: 6px;
                IconButton { icon: @image-url("assets/icons/copy.svg"); clicked => { root.control("copy"); } }
                IconButton { icon: @image-url("assets/icons/paste.svg"); clicked => { root.control("paste"); } }
                IconButton { icon: @image-url("assets/icons/eraser.svg"); clicked => { root.control("clear"); } }
                IconButton { icon: @image-url("assets/icons/refresh.svg"); clicked => { root.control("reconnect"); } }
                IconButton { icon: @image-url("assets/icons/x.svg"); clicked => { root.control("close"); } }
                TextButton { text: "pwd"; clicked => { root.send-command("pwd"); } }
                TextButton { text: "ls -la"; clicked => { root.send-command("ls -la"); } }
                TextButton { text: "df -h"; clicked => { root.send-command("df -h"); } }
                TextButton { text: "free -h"; clicked => { root.send-command("free -h"); } }
                TextButton { text: "ps aux | head"; clicked => { root.send-command("ps aux | head"); } }
                TextButton { text: "whoami"; clicked => { root.send-command("whoami"); } }
                Rectangle { horizontal-stretch: 1; background: transparent; }
                TextField {
                    width: 220px;
                    text <=> root.command;
                    placeholder: "输入命令";
                }
                IconButton {
                    icon: @image-url("assets/icons/send.svg");
                    clicked => {
                        root.send-command(root.command);
                        root.command = "";
                    }
                }
            }
        }
    }
}

component ModalLayer inherits Rectangle {
    in-out property <string> title: "";
    in-out property <string> body: "";
    callback close();
    visible: title != "";
    background: #00000099;
    Rectangle {
        x: (parent.width - 460px) / 2;
        y: 112px;
        width: 460px;
        height: 210px;
        background: Theme.panel;
        border-width: 1px;
        border-color: Theme.line;
        border-radius: 6px;
        VerticalLayout {
            padding: 14px;
            spacing: 10px;
            Text { text: root.title; color: Theme.text; font-size: 14px; font-weight: 800; }
            Text { text: root.body; color: Theme.muted; font-size: 12px; wrap: word-wrap; vertical-stretch: 1; }
            HorizontalLayout {
                Rectangle { horizontal-stretch: 1; background: transparent; }
                TextButton { text: "关闭"; clicked => { root.close(); } }
            }
        }
    }
}

component FilePane inherits Rectangle {
    in property <string> side-title: "本地";
    in-out property <string> path: "";
    in-out property <string> filter: "";
    in property <[FileEntryVm]> entries;
    callback open-path(string);
    callback parent-path(string);
    callback home();
    callback refresh(string);
    callback select-path(string);

    background: Theme.panel;
    border-width: 1px;
    border-color: Theme.line;
    border-radius: 5px;

    VerticalLayout {
        padding: 8px;
        spacing: 5px;
        HorizontalLayout {
            height: 28px;
            Text { width: 36px; text: root.side-title; color: Theme.text; font-size: 12px; font-weight: 700; vertical-alignment: center; }
            TextField { text <=> root.path; placeholder: "路径"; horizontal-stretch: 1; }
            IconButton { icon: @image-url("assets/icons/arrow-right.svg"); clicked => { root.open-path(root.path); } }
            IconButton { icon: @image-url("assets/icons/chevron-left.svg"); clicked => { root.parent-path(root.path); } }
            IconButton { icon: @image-url("assets/icons/home.svg"); clicked => { root.home(); } }
            IconButton { icon: @image-url("assets/icons/up.svg"); clicked => { root.parent-path(root.path); } }
            IconButton { icon: @image-url("assets/icons/refresh.svg"); clicked => { root.refresh(root.path); } }
            IconButton { icon: @image-url("assets/icons/folder-plus.svg"); }
            IconButton { icon: @image-url("assets/icons/edit.svg"); }
            IconButton { icon: @image-url("assets/icons/trash.svg"); }
            IconButton { icon: @image-url("assets/icons/eye-off.svg"); }
            IconButton { icon: @image-url("assets/icons/search.svg"); }
            IconButton { icon: @image-url("assets/icons/download.svg"); }
        }
        HorizontalLayout {
            height: 24px;
            TextField { text <=> root.filter; placeholder: "过滤当前列表"; horizontal-stretch: 1; }
            TextField { text: "收藏路径"; placeholder: "收藏路径"; width: 180px; }
            IconButton { icon: @image-url("assets/icons/bookmark.svg"); }
        }
        Rectangle {
            height: 24px;
            background: Theme.panel2;
            border-width: 1px;
            border-color: Theme.line;
            Text { x: 6px; width: 170px; text: "名称 ↑"; color: Theme.text; font-size: 12px; vertical-alignment: center; }
            Text { x: 180px; width: 58px; text: "权限"; color: Theme.text; font-size: 12px; vertical-alignment: center; }
            Text { x: 250px; width: 58px; text: "属主"; color: Theme.text; font-size: 12px; vertical-alignment: center; }
            Text { x: 320px; width: 70px; text: "大小"; color: Theme.text; font-size: 12px; vertical-alignment: center; }
            Text { x: 410px; width: 120px; text: "时间"; color: Theme.text; font-size: 12px; vertical-alignment: center; }
        }
        ScrollView {
            vertical-stretch: 1;
            Rectangle {
                height: root.entries.length * 26px + 4px;
                background: transparent;
                VerticalLayout {
                    spacing: 0px;
                    for entry in root.entries : Rectangle {
                        height: 26px;
                        background: entry.selected ? Theme.selected : touch.has-hover ? Theme.hover : transparent;
                        Text { x: 6px; width: 170px; text: (entry.is-dir ? "□ " : "▪ ") + entry.name; color: Theme.text; font-size: 12px; vertical-alignment: center; overflow: elide; }
                        Text { x: 180px; width: 58px; text: entry.permissions; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                        Text { x: 250px; width: 58px; text: entry.owner; color: Theme.muted; font-size: 11px; vertical-alignment: center; }
                        Text { x: 320px; width: 70px; text: entry.size; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                        Text { x: 410px; width: parent.width - 416px; text: entry.modified; color: Theme.text; font-size: 11px; vertical-alignment: center; overflow: elide; }
                        touch := TouchArea {
                            clicked => { root.select-path(entry.path); }
                            double-clicked => {
                                if (entry.is-dir) { root.open-path(entry.path); }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "RustShell";
    no-frame: true;
    width: 1420px;
    height: 860px;
    background: Theme.bg;

    in-out property <int> theme-mode: 0;
    changed theme-mode => { Theme.mode = root.theme-mode; }

    in property <[SessionNodeVm]> session-rows;
    in property <[TerminalTabVm]> terminal-tabs;
    in property <[TerminalLineVm]> terminal-lines;
    in-out property <string> session-search: "";
    in-out property <string> quick-host: "";
    in-out property <string> terminal-command: "";
    in-out property <string> modal-title: "";
    in-out property <string> modal-body: "";
    in property <string> preview-name: "";
    in property <string> preview-host: "";
    in property <string> preview-user: "";
    in property <string> preview-protocol: "";
    in property <string> preview-port: "";

    callback refresh-sessions();
    callback select-session(string);
    callback connect-session(string);
    callback connect-quick(string);
    callback open-local-terminal();
    callback open-file-manager();
    callback open-settings();
    callback terminal-control(string);
    callback send-terminal-command(string);
    callback window-action(string);
    callback close-modal();

    VerticalLayout {
        width: root.width;
        height: root.height;
        spacing: 0px;
        TopMenu {
            width: root.width;
            open-file-manager => { root.open-file-manager(); }
            open-settings => { root.open-settings(); }
            open-local => { root.open-local-terminal(); }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg;
            SessionPanel {
                x: 0px;
                y: 0px;
                height: parent.height;
                rows: root.session-rows;
                search: root.session-search;
                preview-name: root.preview-name;
                preview-host: root.preview-host;
                preview-user: root.preview-user;
                preview-protocol: root.preview-protocol;
                preview-port: root.preview-port;
                refresh => { root.refresh-sessions(); }
                select(id) => { root.select-session(id); }
                connect(id) => { root.connect-session(id); }
            }
            Rectangle {
                x: 272px;
                y: 0px;
                width: 8px;
                height: parent.height;
                background: Theme.bg;
            }
            TerminalArea {
                x: 280px;
                y: 0px;
                width: parent.width - 280px;
                height: parent.height;
                tabs: root.terminal-tabs;
                lines: root.terminal-lines;
                command <=> root.terminal-command;
                control(action) => { root.terminal-control(action); }
                send-command(command) => { root.send-terminal-command(command); }
            }
        }
    }

    Rectangle {
        x: 930px;
        y: 11px;
        width: 304px;
        height: 28px;
        TextField {
            width: parent.width;
            text <=> root.quick-host;
            placeholder: "主机名、IP 或会话名称";
        }
    }
    TextButton {
        x: 1240px;
        y: 11px;
        width: 48px;
        text: "连接";
        primary: true;
        clicked => { root.connect-quick(root.quick-host); }
    }
    WindowButton { x: root.width - 116px; y: 8px; symbol: "−"; clicked => { root.window-action("minimize"); } }
    WindowButton { x: root.width - 76px; y: 8px; symbol: "↗"; clicked => { root.window-action("maximize"); } }
    WindowButton { x: root.width - 38px; y: 8px; symbol: "×"; clicked => { root.window-action("close"); } }

    ModalLayer {
        width: root.width;
        height: root.height;
        title <=> root.modal-title;
        body <=> root.modal-body;
        close => { root.close-modal(); }
    }
}

export component FileManagerWindow inherits Window {
    title: "RustShell File Manager";
    no-frame: true;
    width: 1180px;
    height: 760px;
    background: Theme.bg;

    in-out property <int> theme-mode: 0;
    changed theme-mode => { Theme.mode = root.theme-mode; }

    in property <[FileEntryVm]> local-entries;
    in property <[FileEntryVm]> remote-entries;
    in-out property <string> local-path: "";
    in-out property <string> remote-path: "/root";
    in-out property <string> local-filter: "";
    in-out property <string> remote-filter: "";
    in-out property <string> remote-selector: "";
    in-out property <string> modal-title: "";
    in-out property <string> modal-body: "";

    callback refresh-local(string);
    callback refresh-remote(string, string);
    callback local-home();
    callback remote-home();
    callback local-parent(string);
    callback remote-parent(string);
    callback select-local(string);
    callback select-remote(string);
    callback transfer(string);
    callback window-action(string);
    callback close-modal();

    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 10px;
        spacing: 8px;

        HorizontalLayout {
            width: parent.width;
            height: 30px;
            Text { width: 150px; text: "文件管理器"; color: Theme.text; font-size: 14px; font-weight: 800; vertical-alignment: center; }
            Rectangle { horizontal-stretch: 1; background: transparent; }
            TextField { width: 320px; text <=> root.remote-selector; placeholder: "选择远程会话"; }
            IconButton { icon: @image-url("assets/icons/folder.svg"); clicked => { root.refresh-remote(root.remote-selector, root.remote-path); } }
            IconButton { icon: @image-url("assets/icons/upload.svg"); clicked => { root.transfer("upload"); } }
            IconButton { icon: @image-url("assets/icons/calculator.svg"); }
            IconButton { icon: @image-url("assets/icons/list.svg"); }
            WindowButton { symbol: "−"; clicked => { root.window-action("minimize"); } }
            WindowButton { symbol: "↗"; clicked => { root.window-action("maximize"); } }
            WindowButton { symbol: "×"; clicked => { root.window-action("hide"); } }
        }

        HorizontalLayout {
            width: parent.width;
            spacing: 10px;
            vertical-stretch: 1;
            FilePane {
                horizontal-stretch: 1;
                side-title: "本地";
                path <=> root.local-path;
                filter <=> root.local-filter;
                entries: root.local-entries;
                open-path(path) => { root.refresh-local(path); }
                parent-path(path) => { root.local-parent(path); }
                home => { root.local-home(); }
                refresh(path) => { root.refresh-local(path); }
                select-path(path) => { root.select-local(path); }
            }
            FilePane {
                horizontal-stretch: 1;
                side-title: "远程";
                path <=> root.remote-path;
                filter <=> root.remote-filter;
                entries: root.remote-entries;
                open-path(path) => { root.refresh-remote(root.remote-selector, path); }
                parent-path(path) => { root.remote-parent(path); }
                home => { root.remote-home(); }
                refresh(path) => { root.refresh-remote(root.remote-selector, path); }
                select-path(path) => { root.select-remote(path); }
            }
        }
    }

    ModalLayer {
        width: root.width;
        height: root.height;
        title <=> root.modal-title;
        body <=> root.modal-body;
        close => { root.close-modal(); }
    }
}
